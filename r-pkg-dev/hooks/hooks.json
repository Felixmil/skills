{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/air-format.sh",
            "statusMessage": "air format"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-r-code.sh",
            "statusMessage": "R code guardrail"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|mcp__r-btw__btw_tool_pkg_document",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-pkgdown-index.sh",
            "statusMessage": "pkgdown index check"
          }
        ]
      }
    ]
  }
}

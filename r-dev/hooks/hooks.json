{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/check-roxygen-before-commit.mjs\"",
            "statusMessage": "r-dev gate: checking roxygen docs are up to date before commit"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/check-pkgdown-index.mjs\"",
            "statusMessage": "r-dev gate: checking the pkgdown reference index is in sync before commit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/air-format.mjs\"",
            "statusMessage": "air format"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/check-r-code.mjs\"",
            "statusMessage": "R code guardrail"
          }
        ]
      }
    ]
  }
}
